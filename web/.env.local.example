# Supabase — Dashboard → Project Settings → API
# Bu dosyayı .env.local olarak kopyalayın (git'e eklenmez).

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Sunucu tarafı — ASLA NEXT_PUBLIC_ yapmayın, tarayıcıya gönderilmez.
# Dashboard → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=eyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Admin girişi
ADMIN_USERNAME=admin
ADMIN_PASSWORD=guclu-bir-sifre

# Oturum imzası (uzun, rastgele bir dize)
SESSION_SECRET=super-secret-string

# İsteğe bağlı — oturum süresi (saat), varsayılan: 8
SESSION_MAX_AGE_HOURS=8
